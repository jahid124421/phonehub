---
const year = new Date().getFullYear();

const links = {
  product: [
    { label: 'Home', href: '/phonehub/' },
    { label: 'Search', href: '/phonehub/search' },
    { label: 'Compare', href: '/phonehub/compare' },
    { label: 'News', href: '/phonehub/news' },
    { label: 'Brands', href: '/phonehub/brands' },
  ],
  categories: [
    { label: 'Phones', href: '/phonehub/search?cat=phone' },
    { label: 'Laptops', href: '/phonehub/search?cat=laptop' },
    { label: 'TVs', href: '/phonehub/search?cat=tv' },
    { label: 'Cars', href: '/phonehub/search?cat=auto' },
    { label: 'Watches', href: '/phonehub/search?cat=smartwatch' },
  ],
  legal: [
    { label: 'Privacy Policy', href: '/phonehub/privacy' },
    { label: 'Terms of Service', href: '/phonehub/terms' },
    { label: 'Disclosure', href: '/phonehub/disclosure' },
    { label: 'About', href: '/phonehub/about' },
  ],
};
---

<footer class="bg-navy-900 border-t border-white/5 mt-16">
  <div class="max-w-7xl mx-auto px-4 py-12 md:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <a href="/phonehub/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent-blue to-accent-purple flex items-center justify-center text-white font-bold text-sm">
            P
          </div>
          <span class="text-lg font-bold text-white">PhoneHub</span>
        </a>
        <p class="text-sm text-gray-500 leading-relaxed">
          Find, compare & decide. The smartest way to research tech products.
        </p>
      </div>

      <!-- Product links -->
      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Product</h3>
        <ul class="space-y-2">
          {links.product.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 hover:text-accent-blue transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Categories</h3>
        <ul class="space-y-2">
          {links.categories.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 hover:text-accent-blue transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-2">
          {links.legal.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 hover:text-accent-blue transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-600">
        &copy; {year} PhoneHub. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <!-- GitHub -->
        <a href="https://github.com/jahid124421" target="_blank" rel="noopener" class="text-gray-600 hover:text-gray-400 transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
