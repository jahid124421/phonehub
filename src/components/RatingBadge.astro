---
interface Props {
  rating: number;
  reviewCount?: number;
}

const { rating, reviewCount } = Astro.props;

const colorClass =
  rating >= 4 ? 'text-green-400 border-green-400/30' :
  rating >= 3 ? 'text-yellow-400 border-yellow-400/30' :
  rating >= 2 ? 'text-orange-400 border-orange-400/30' :
  'text-red-400 border-red-400/30';

const bgClass =
  rating >= 4 ? 'from-green-500/10' :
  rating >= 3 ? 'from-yellow-500/10' :
  rating >= 2 ? 'from-orange-500/10' :
  'from-red-500/10';

const percentage = Math.round((rating / 5) * 100);
const circumference = 2 * Math.PI * 18;
const offset = circumference - (percentage / 100) * circumference;

const stars = Array.from({ length: 5 }, (_, i) => i < Math.round(rating));
---

{rating > 0 && (
  <div class="flex flex-col items-center gap-1">
    <div class={`relative w-14 h-14 flex items-center justify-center`}>
      <!-- SVG circular progress -->
      <svg class="absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 40 40">
        <circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="2" class="text-white/5" />
        <circle
          cx="20" cy="20" r="18" fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-dasharray={circumference}
          stroke-dashoffset={offset}
          class={colorClass}
        />
      </svg>
      <span class={`text-sm font-bold ${colorClass.split(' ')[0]}`}>
        {rating.toFixed(1)}
      </span>
    </div>

    <!-- Stars -->
    <div class="flex gap-0.5">
      {stars.map((filled) => (
        <svg class={`w-3 h-3 ${filled ? 'text-yellow-500' : 'text-gray-700'}`} fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>

    {reviewCount != null && reviewCount > 0 && (
      <span class="text-[10px] text-gray-500">{reviewCount.toLocaleString()} reviews</span>
    )}
  </div>
)}
