---
import { formatNewsDate } from '../utils/formatters';

interface Props {
  article: any;
}

const { article } = Astro.props;
---

<a
  href={article.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group block"
>
  <article class="glass-card-hover overflow-hidden flex flex-col sm:flex-row h-full">
    <!-- Image -->
    <div class="sm:w-48 md:w-56 flex-shrink-0 overflow-hidden">
      {article.image ? (
        <img
          src={article.image}
          alt={article.title}
          class="w-full h-40 sm:h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
          onerror="this.parentElement.innerHTML='<div class=\'w-full h-40 sm:h-full bg-navy-800/60 flex items-center justify-center text-gray-600\'><svg class=\'w-8 h-8\' fill=\'none\' stroke=\'currentColor\' viewBox=\'0 0 24 24\'><path stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'1\' d=\'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z\' /></svg></div>'"
        />
      ) : (
        <div class="w-full h-40 sm:h-full bg-navy-800/60 flex items-center justify-center text-gray-600">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
      )}
    </div>

    <!-- Content -->
    <div class="p-4 flex flex-col flex-1 gap-2 min-w-0">
      <!-- Tag + Source -->
      <div class="flex items-center gap-2 text-[10px]">
        {article.tag && (
          <span class="px-2 py-0.5 rounded-full bg-accent-blue/10 text-accent-blue font-medium">
            {article.tag}
          </span>
        )}
        <span class="text-gray-500">{article.source}</span>
        <span class="text-gray-700">&bull;</span>
        <span class="text-gray-500">{formatNewsDate(article.date)}</span>
      </div>

      <!-- Title -->
      <h3 class="text-sm font-semibold text-gray-200 group-hover:text-white transition-colors line-clamp-2">
        {article.title}
      </h3>

      <!-- Excerpt -->
      {article.excerpt && (
        <p class="text-xs text-gray-500 line-clamp-3 leading-relaxed">
          {article.excerpt}
        </p>
      )}

      <!-- Read more -->
      <span class="mt-auto text-[11px] text-accent-blue/70 font-medium group-hover:text-accent-blue transition-colors">
        Read more &rarr;
      </span>
    </div>
  </article>
</a>
