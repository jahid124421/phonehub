---
interface Props {
  placeholder?: string;
  initialQuery?: string;
  autofocus?: boolean;
}

const { placeholder = 'Search phones, laptops, cars...', initialQuery = '', autofocus = false } = Astro.props;
---

<form action="/phonehub/search" method="get" class="relative w-full max-w-2xl mx-auto" id="search-form">
  <div class="relative">
    <input
      type="text"
      name="q"
      value={initialQuery}
      placeholder={placeholder}
      {autofocus}
      class="w-full h-12 md:h-14 pl-12 pr-4 rounded-full bg-navy-800/60 backdrop-blur-xl border border-white/10 text-base text-gray-200 placeholder-gray-500 focus:outline-none focus:border-accent-blue/50 focus:bg-navy-700/80 focus:shadow-lg focus:shadow-accent-blue/10 transition-all"
    />
    <button type="submit" class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-accent-blue transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </button>
  </div>
</form>

<script>
  const form = document.getElementById('search-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      const input = form.querySelector('input[name="q"]') as HTMLInputElement;
      if (!input.value.trim()) {
        e.preventDefault();
      }
    });
  }
</script>
