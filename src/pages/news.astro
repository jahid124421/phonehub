---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsCard from '../components/NewsCard.astro';
import news from '../../data/news.json';

// Sort by date descending
const sortedNews = [...news].sort(
  (a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

// Extract unique sources
const sourceSet = new Set<string>();
sortedNews.forEach((n: any) => { if (n.source) sourceSet.add(n.source); });
const sources = Array.from(sourceSet).sort();
---

<BaseLayout
  title="Latest News — PhoneHub"
  description="Latest tech news from Android Authority, The Verge, TechCrunch, 9to5Google, and more."
>
  <section class="max-w-7xl mx-auto px-4 py-10">
    <!-- Heading -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">Tech News</h1>
      <p class="text-gray-400 text-sm">Latest from the world of phones, tech and more</p>
    </div>

    <!-- Source filter pills -->
    <div class="mb-8 flex gap-2 overflow-x-auto pb-2 scrollbar-none -mx-4 px-4" id="source-pills">
      <button
        data-source="all"
        class="source-pill active flex-shrink-0 px-4 py-1.5 rounded-full text-xs font-medium transition-all bg-accent-blue text-white"
      >
        All
      </button>
      {sources.map((src) => (
        <button
          data-source={src}
          class="source-pill flex-shrink-0 px-4 py-1.5 rounded-full text-xs font-medium transition-all bg-navy-800/60 border border-white/10 text-gray-400 hover:bg-navy-700/60 hover:text-gray-200"
        >
          {src}
        </button>
      ))}
    </div>

    <!-- News count -->
    <p class="text-xs text-gray-500 mb-4" id="news-count">
      Showing <span id="count-num">{sortedNews.length}</span> articles
    </p>

    <!-- News grid -->
    <div class="grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3" id="news-grid">
      {sortedNews.map((article: any) => (
        <div class="news-item" data-source={article.source}>
          <NewsCard article={article} />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const pills = document.querySelectorAll('.source-pill');
  const items = document.querySelectorAll('.news-item');
  const countNum = document.getElementById('count-num')!;

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const source = (pill as HTMLElement).dataset.source!;

      // Update active pill styling
      pills.forEach(p => {
        p.classList.remove('bg-accent-blue', 'text-white', 'active');
        p.classList.add('bg-navy-800/60', 'border', 'border-white/10', 'text-gray-400');
      });
      pill.classList.remove('bg-navy-800/60', 'border', 'border-white/10', 'text-gray-400');
      pill.classList.add('bg-accent-blue', 'text-white', 'active');

      // Filter items
      let count = 0;
      items.forEach(item => {
        const itemSource = (item as HTMLElement).dataset.source;
        if (source === 'all' || itemSource === source) {
          (item as HTMLElement).style.display = '';
          count++;
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });

      countNum.textContent = String(count);
    });
  });
</script>
