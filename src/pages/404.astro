---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
---

<BaseLayout
  title="Page Not Found — PhoneHub"
  description="The page you're looking for doesn't exist. Search for products or return to the homepage."
>
  <section class="max-w-2xl mx-auto px-4 py-20 flex flex-col items-center text-center">
    <!-- 404 Illustration -->
    <div class="glass-card p-10 mb-10 w-full">
      <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-navy-700/40 border border-white/5 mb-6">
        <svg class="w-12 h-12 text-accent-blue/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>

      <h1 class="text-5xl md:text-6xl font-black text-white mb-3">
        4<span class="text-accent-blue">0</span>4
      </h1>
      <h2 class="text-xl font-semibold text-gray-300 mb-3">Page Not Found</h2>
      <p class="text-sm text-gray-500 mb-8 max-w-md mx-auto">
        Oops! The page you're looking for doesn't exist, has been moved, or is temporarily unavailable. Maybe you followed a broken link or typed the wrong URL.
      </p>

      <!-- Search -->
      <div class="mb-8">
        <p class="text-xs text-gray-500 mb-3">Try searching for what you need:</p>
        <SearchBar placeholder="Search for products..." />
      </div>

      <!-- Quick links -->
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="/phonehub/"
          class="px-5 py-2 rounded-xl bg-accent-blue text-white text-sm font-semibold hover:bg-accent-blue/90 transition-all"
        >
          Go to Homepage
        </a>
        <a
          href="/phonehub/compare"
          class="px-5 py-2 rounded-xl bg-navy-700/60 border border-white/10 text-sm text-gray-300 hover:bg-navy-600/60 hover:text-white transition-all"
        >
          Compare Products
        </a>
        <a
          href="/phonehub/news"
          class="px-5 py-2 rounded-xl bg-navy-700/60 border border-white/10 text-sm text-gray-300 hover:bg-navy-600/60 hover:text-white transition-all"
        >
          Latest News
        </a>
      </div>
    </div>

    <p class="text-xs text-gray-600">
      If you believe this is an error, please <a href="/phonehub/contact" class="text-accent-blue hover:underline">let us know</a>.
    </p>
  </section>
</BaseLayout>
