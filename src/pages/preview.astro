<style is:global>
/* ===== GLOBAL ===== */
* { margin:0; padding:0; box-sizing:border-box; }
body { background:#050810; color:#fff; font-family:'Inter',sans-serif; overflow-x:hidden; }
.theme-section { position:relative; width:100%; }
.sticky-label {
  position:sticky; top:0; z-index:100;
  background:linear-gradient(90deg,#00f0ff,#ff00ff);
  color:#000; font-family:'Orbitron',sans-serif; font-weight:700; font-size:1rem;
  padding:10px 24px; text-align:center; letter-spacing:2px;
}
.sticky-label.label-b { background:linear-gradient(90deg,#00a8ff,#ffa800); }
.sticky-label.label-c { background:linear-gradient(90deg,#06b6d4,#8b5cf6,#ec4899); }
.sticky-label.label-d { background:linear-gradient(90deg,#00ff88,#00cccc); }
.sticky-label.label-e { background:linear-gradient(90deg,#8b5cf6,#06b6d4,#f59e0b); }

/* NAV */
.preview-nav {
  position:sticky; top:0; z-index:200;
  background:rgba(5,8,16,0.95); backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(255,255,255,0.1);
}
.nav-inner {
  max-width:1400px; margin:0 auto; display:flex; align-items:center;
  justify-content:space-between; padding:12px 24px; flex-wrap:wrap; gap:8px;
}
.nav-logo { font-family:'Orbitron',sans-serif; font-weight:700; font-size:1.1rem; color:#fff; }
.nav-logo small { font-size:0.7rem; color:#888; font-weight:400; }
.nav-links { display:flex; gap:12px; flex-wrap:wrap; }
.nav-links a {
  color:#aaa; text-decoration:none; font-size:0.8rem; padding:4px 10px;
  border-radius:4px; transition:all 0.3s;
}
.nav-links a:hover { color:#fff; background:rgba(255,255,255,0.1); }

/* ===== OPTION A: NEON CYBERPUNK ===== */
.theme-a { background:#0a0e1a; font-family:'Inter',sans-serif; }
.theme-a h1,.theme-a h2,.theme-a h3,.theme-a .a-logo { font-family:'Orbitron',sans-serif; }

.a-header { background:rgba(10,14,26,0.9); border-bottom:1px solid rgba(0,240,255,0.2); padding:12px 0; }
.a-header-inner { max-width:1200px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; padding:0 24px; }
.a-logo { color:#00f0ff; font-size:1.3rem; font-weight:700; text-shadow:0 0 10px rgba(0,240,255,0.5); }
.a-nav { display:flex; gap:20px; }
.a-nav a { color:#8899aa; text-decoration:none; font-size:0.85rem; transition:color 0.3s; }
.a-nav a:hover { color:#00f0ff; }

.a-hero {
  position:relative; height:400px; display:flex; align-items:center; justify-content:center;
  overflow:hidden;
}
.a-hero-mesh {
  position:absolute; inset:0;
