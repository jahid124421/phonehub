---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCategoryLabel, getCategoryIcon } from '../utils/formatters';

import SkeletonCard from '../components/SkeletonCard.astro';

import products from '../../data/products.json';
import brands from '../../data/brands.json';

// Build category counts
const catCounts: Record<string, number> = {};
(products as any[]).forEach((p) => {
  const cat = p.category || 'other';
  catCounts[cat] = (catCounts[cat] || 0) + 1;
});

// Build brand counts
const brandCounts: Record<string, number> = {};
(products as any[]).forEach((p) => {
  const b = p.brand || 'unknown';
  brandCounts[b] = (brandCounts[b] || 0) + 1;
});

// Sort brands by count desc
const sortedBrands = (brands as any[])
  .filter((b) => brandCounts[b.id])
  .sort((a, b) => (brandCounts[b.id] || 0) - (brandCounts[a.id] || 0));

// Serialize minimal product data for client-side filtering
const serializedProducts = (products as any[]).map((p) => ({
  id: p.id,
  brand: p.brand,
  name: p.name,
  category: p.category || 'other',
  image: p.image || '',
  fallbackImg: p.fallbackImg || '',
  releaseDate: p.releaseDate || '',
  basePrice: p.basePrice || 0,
  popularity: p.popularity || 0,
  rating: p.rating || 0,
  reviewCount: p.reviewCount || 0,
  quickSpecs: p.quickSpecs || {},
}));

const totalProducts = (products as any[]).length;
---

<BaseLayout title="Search — PhoneHub" description={`Browse ${totalProducts}+ products with detailed specs, reviews & pricing.`}>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-8" data-aos="fade-up">
      <h1 class="text-2xl md:text-3xl font-bold text-white">All Products</h1>
      <span class="px-3 py-1 rounded-full bg-accent-blue/10 border border-accent-blue/20 text-xs font-semibold text-accent-blue">
        {totalProducts.toLocaleString()}
      </span>
    </div>

    <!-- Mobile filter toggle -->
    <button
      id="filter-toggle"
      class="lg:hidden mb-4 px-4 py-2.5 rounded-xl bg-navy-700 border border-white/10 text-gray-300 text-sm font-semibold hover:bg-navy-600 transition-all flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
      </svg>
      Filters
    </button>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Filter Sidebar -->
      <aside id="filter-sidebar" class="hidden lg:block w-full lg:w-72 flex-shrink-0">
        <div class="sticky top-4 space-y-6">
          <!-- Search -->
          <div>
            <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 block">Search</label>
            <div class="relative">
              <input
                type="text"
                id="search-input"
                placeholder="Search products..."
                class="w-full px-4 py-2.5 pl-10 rounded-xl bg-navy-800 border border-white/10 text-sm text-gray-200 placeholder:text-gray-600 focus:outline-none focus:border-accent-blue/50 transition-colors"
              />
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
          </div>

          <!-- Category Filter -->
          <div>
            <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3 block">Category</label>
            <div class="space-y-1.5" id="category-filters">
              {Object.entries(catCounts)
                .sort(([, a], [, b]) => b - a)
                .map(([cat, count]) => (
                  <label class="flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-navy-700/50 cursor-pointer group">
                    <input
                      type="checkbox"
                      name="category"
                      value={cat}
                      class="checkbox checkbox-xs checkbox-primary"
                    />
                    <span class="text-sm text-gray-400 group-hover:text-gray-200 transition-colors flex-1">
                      {getCategoryIcon(cat)} {getCategoryLabel(cat)}
                    </span>
                    <span class="text-[10px] text-gray-600">{count}</span>
                  </label>
                ))}
            </div>
          </div>

          <!-- Brand Filter -->
          <div>
            <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 block">Brand</label>
            <input
              type="text"
              id="brand-search"
              placeholder="Filter brands..."
              class="w-full px-3 py-2 rounded-lg bg-navy-800 border border-white/10 text-xs text-gray-200 placeholder:text-gray-600 focus:outline-none focus:border-accent-blue/50 mb-2"
            />
            <div class="space-y-1 max-h-64 overflow-y-auto pr-1" id="brand-filters">
              {sortedBrands.map((b) => (
                <label
                  class="brand-option flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-navy-700/50 cursor-pointer group"
                  data-brand={b.id}
                >
                  <input
                    type="checkbox"
                    name="brand"
                    value={b.id}
                    class="checkbox checkbox-xs checkbox-primary"
                  />
                  <span class="text-sm text-gray-400 group-hover:text-gray-200 transition-colors flex-1 truncate">
                    {b.name}
                  </span>
                  <span class="text-[10px] text-gray-600">{brandCounts[b.id] || 0}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Price Range -->
          <div>
            <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 block">Price Range</label>
            <div class="flex items-center gap-2">
              <input
                type="number"
                id="price-min"
                placeholder="Min"
                min="0"
                class="w-full px-3 py-2 rounded-lg bg-navy-800 border border-white/10 text-xs text-gray-200 placeholder:text-gray-600 focus:outline-none focus:border-accent-blue/50"
              />
              <span class="text-gray-600">—</span>
              <input
                type="number"
                id="price-max"
                placeholder="Max"
                min="0"
                class="w-full px-3 py-2 rounded-lg bg-navy-800 border border-white/10 text-xs text-gray-200 placeholder:text-gray-600 focus:outline-none focus:border-accent-blue/50"
              />
            </div>
          </div>

          <!-- Rating Filter -->
          <div>
            <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 block">Min Rating</label>
            <div class="flex gap-2" id="rating-filter">
              {[4, 3, 2, 1].map((r) => (
                <button
                  class="rating-btn px-3 py-1.5 rounded-lg bg-navy-800 border border-white/10 text-xs text-gray-400 hover:border-accent-blue/40 hover:text-accent-blue transition-all"
                  data-rating={r}
                >
                  {r}+
                </button>
              ))}
            </div>
          </div>

          <!-- Clear -->
          <button
            id="clear-filters"
            class="w-full px-4 py-2.5 rounded-xl bg-navy-700/50 border border-white/5 text-gray-500 text-xs font-medium hover:text-gray-300 hover:bg-navy-700 transition-all"
          >
            Clear all filters
          </button>
        </div>
      </aside>

      <!-- Results Area -->
      <div class="flex-1 min-w-0">
        <!-- Sort + Count bar -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-6">
          <p id="results-count" class="text-sm text-gray-500">
            Showing {totalProducts} of {totalProducts} products
          </p>
          <div class="flex items-center gap-2">
            <label class="text-xs text-gray-500">Sort:</label>
            <select
              id="sort-select"
              class="px-3 py-2 rounded-lg bg-navy-800 border border-white/10 text-xs text-gray-200 focus:outline-none focus:border-accent-blue/50"
            >
              <option value="popularity">Popularity</option>
              <option value="rating">Rating</option>
              <option value="price-asc">Price: Low → High</option>
              <option value="price-desc">Price: High → Low</option>
              <option value="name">Name (A–Z)</option>
              <option value="newest">Newest</option>
            </select>
          </div>
        </div>

        <!-- Skeleton loading state -->
        <div id="skeleton-grid" class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4 mb-4">
          {Array.from({ length: 8 }).map(() => (
            <SkeletonCard />
          ))}
        </div>

        <!-- Product Grid -->
        <div id="product-grid" class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4" data-aos="fade-up">
          {(products as any[]).map((p) => (
            <div
              class="product-item"
              data-id={p.id}
              data-brand={p.brand}
              data-category={p.category || 'other'}
              data-price={p.basePrice || 0}
              data-rating={p.rating || 0}
              data-popularity={p.popularity || 0}
              data-name={p.name.toLowerCase()}
              data-date={p.releaseDate || ''}
            >
              <ProductCard product={p} />
            </div>
          ))}
        </div>

        <!-- Empty state -->
        <div id="no-results" class="hidden text-center py-16">
          <svg class="w-16 h-16 mx-auto text-gray-700 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <h3 class="text-lg font-semibold text-gray-400 mb-2">No products found</h3>
          <p class="text-sm text-gray-600">Try adjusting your filters or search query.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Serialized product data for client-side search -->
  <script set:html={`window.__PRODUCTS__ = ${JSON.stringify(serializedProducts)};`} />

  <!-- FlexSearch CDN -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/flexsearch@0.7.43/dist/flexsearch.bundle.min.js" />

  <!-- Client-side filtering logic -->
  <script is:inline>
    (function () {
      const params = new URLSearchParams(window.location.search);
      const grid = document.getElementById('product-grid');
      const items = Array.from(grid.querySelectorAll('.product-item'));
      const noResults = document.getElementById('no-results');
      const resultsCount = document.getElementById('results-count');
      const searchInput = document.getElementById('search-input');
      const sortSelect = document.getElementById('sort-select');
      const brandSearch = document.getElementById('brand-search');
      const clearBtn = document.getElementById('clear-filters');
      const filterToggle = document.getElementById('filter-toggle');
      const sidebar = document.getElementById('filter-sidebar');

      // State
      let selectedCats = new Set();
      let selectedBrands = new Set();
      let minRating = 0;
      let priceMin = 0;
      let priceMax = Infinity;
      let searchQuery = '';
      let sortBy = 'popularity';

      // Initialize FlexSearch
      let searchIndex = null;
      if (typeof FlexSearch !== 'undefined') {
        searchIndex = new FlexSearch.Document({
          document: { id: 'id', index: ['name', 'brand'] },
          tokenize: 'forward',
        });
        (window.__PRODUCTS__ || []).forEach(function (p) {
          searchIndex.add({ id: p.id, name: p.name, brand: p.brand });
        });
      }

      // Read URL params
      if (params.get('cat')) {
        params.get('cat').split(',').forEach(function (c) { selectedCats.add(c); });
      }
      if (params.get('brand')) {
        params.get('brand').split(',').forEach(function (b) { selectedBrands.add(b); });
      }
      if (params.get('q')) {
        searchQuery = params.get('q');
        searchInput.value = searchQuery;
      }
      if (params.get('sort')) {
        sortBy = params.get('sort');
        sortSelect.value = sortBy;
      }
      if (params.get('rating')) {
        minRating = parseInt(params.get('rating')) || 0;
      }

      // Check initial checkboxes
      document.querySelectorAll('input[name="category"]').forEach(function (cb) {
        if (selectedCats.has(cb.value)) cb.checked = true;
      });
      document.querySelectorAll('input[name="brand"]').forEach(function (cb) {
        if (selectedBrands.has(cb.value)) cb.checked = true;
      });
      if (minRating > 0) {
        document.querySelectorAll('.rating-btn').forEach(function (btn) {
          if (parseInt(btn.dataset.rating) === minRating) btn.classList.add('!border-accent-blue', '!text-accent-blue');
        });
      }

      // Mobile filter toggle
      filterToggle.addEventListener('click', function () {
        sidebar.classList.toggle('hidden');
        sidebar.classList.toggle('block');
      });

      // Debounce helper
      function debounce(fn, ms) {
        let t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }

      function updateURL() {
        const p = new URLSearchParams();
        if (selectedCats.size) p.set('cat', Array.from(selectedCats).join(','));
        if (selectedBrands.size) p.set('brand', Array.from(selectedBrands).join(','));
        if (searchQuery) p.set('q', searchQuery);
        if (sortBy !== 'popularity') p.set('sort', sortBy);
        if (minRating > 0) p.set('rating', minRating);
        if (priceMin > 0) p.set('pmin', priceMin);
        if (priceMax < Infinity) p.set('pmax', priceMax);
        const qs = p.toString();
        const newUrl = window.location.pathname + (qs ? '?' + qs : '');
        history.replaceState(null, '', newUrl);
      }

      function getSearchMatches() {
        if (!searchQuery) return null;
        if (!searchIndex) {
          // Fallback: simple includes
          var q = searchQuery.toLowerCase();
          var matches = new Set();
          (window.__PRODUCTS__ || []).forEach(function (p) {
            if (p.name.toLowerCase().includes(q) || p.brand.toLowerCase().includes(q)) {
              matches.add(p.id);
            }
          });
          return matches;
        }
        var results = searchIndex.search(searchQuery, { enrich: true });
        var matches = new Set();
        results.forEach(function (r) {
          r.result.forEach(function (id) { matches.add(id); });
        });
        return matches;
      }

      function applyFilters() {
        var searchMatches = getSearchMatches();
        var visibleCount = 0;

        items.forEach(function (item) {
          var brand = item.dataset.brand;
          var cat = item.dataset.category;
          var price = parseFloat(item.dataset.price) || 0;
          var rating = parseFloat(item.dataset.rating) || 0;
          var id = item.dataset.id;

          var show = true;

          // Category filter
          if (selectedCats.size > 0 && !selectedCats.has(cat)) show = false;
          // Brand filter
          if (show && selectedBrands.size > 0 && !selectedBrands.has(brand)) show = false;
          // Rating filter
          if (show && minRating > 0 && rating < minRating) show = false;
          // Price filter
          if (show && price > 0) {
            if (price < priceMin || price > priceMax) show = false;
          } else if (show && priceMin > 0) {
            show = false;
          }
          // Search filter
          if (show && searchMatches !== null && !searchMatches.has(id)) show = false;

          item.style.display = show ? '' : 'none';
          if (show) visibleCount++;
        });

        // Sort
        sortItems();

        // Update count
        resultsCount.textContent = 'Showing ' + visibleCount + ' of ' + items.length + ' products';

        // Empty state
        if (visibleCount === 0) {
          noResults.classList.remove('hidden');
          grid.classList.add('hidden');
        } else {
          noResults.classList.add('hidden');
          grid.classList.remove('hidden');
        }

        updateURL();
      }

      function sortItems() {
        var sorted = items.slice().sort(function (a, b) {
          switch (sortBy) {
            case 'rating':
              return (parseFloat(b.dataset.rating) || 0) - (parseFloat(a.dataset.rating) || 0);
            case 'price-asc':
              return (parseFloat(a.dataset.price) || 0) - (parseFloat(b.dataset.price) || 0);
            case 'price-desc':
              return (parseFloat(b.dataset.price) || 0) - (parseFloat(a.dataset.price) || 0);
            case 'name':
              return a.dataset.name.localeCompare(b.dataset.name);
            case 'newest':
              return (b.dataset.date || '').localeCompare(a.dataset.date || '');
            default:
              return (parseFloat(b.dataset.popularity) || 0) - (parseFloat(a.dataset.popularity) || 0);
          }
        });
        sorted.forEach(function (item) {
          grid.appendChild(item);
        });
      }

      // Event listeners
      document.querySelectorAll('input[name="category"]').forEach(function (cb) {
        cb.addEventListener('change', function () {
          if (cb.checked) selectedCats.add(cb.value);
          else selectedCats.delete(cb.value);
          applyFilters();
        });
      });

      document.querySelectorAll('input[name="brand"]').forEach(function (cb) {
        cb.addEventListener('change', function () {
          if (cb.checked) selectedBrands.add(cb.value);
          else selectedBrands.delete(cb.value);
          applyFilters();
        });
      });

      document.querySelectorAll('.rating-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var r = parseInt(btn.dataset.rating);
          if (minRating === r) {
            minRating = 0;
            btn.classList.remove('!border-accent-blue', '!text-accent-blue');
          } else {
            document.querySelectorAll('.rating-btn').forEach(function (b) {
              b.classList.remove('!border-accent-blue', '!text-accent-blue');
            });
            minRating = r;
            btn.classList.add('!border-accent-blue', '!text-accent-blue');
          }
          applyFilters();
        });
      });

      searchInput.addEventListener('input', debounce(function () {
        searchQuery = searchInput.value.trim();
        applyFilters();
      }, 300));

      sortSelect.addEventListener('change', function () {
        sortBy = sortSelect.value;
        applyFilters();
      });

      brandSearch.addEventListener('input', function () {
        var q = brandSearch.value.toLowerCase();
        document.querySelectorAll('.brand-option').forEach(function (opt) {
          var name = opt.dataset.brand || '';
          var label = opt.querySelector('span').textContent.toLowerCase();
          opt.style.display = label.includes(q) || name.includes(q) ? '' : 'none';
        });
      });

      document.getElementById('price-min').addEventListener('input', debounce(function () {
        priceMin = parseFloat(this.value) || 0;
        applyFilters();
      }, 500));

      document.getElementById('price-max').addEventListener('input', debounce(function () {
        priceMax = parseFloat(this.value) || Infinity;
        applyFilters();
      }, 500));

      clearBtn.addEventListener('click', function () {
        selectedCats.clear();
        selectedBrands.clear();
        minRating = 0;
        priceMin = 0;
        priceMax = Infinity;
        searchQuery = '';
        sortBy = 'popularity';
        searchInput.value = '';
        sortSelect.value = 'popularity';
        document.getElementById('price-min').value = '';
        document.getElementById('price-max').value = '';
        document.querySelectorAll('input[name="category"], input[name="brand"]').forEach(function (cb) {
          cb.checked = false;
        });
        document.querySelectorAll('.rating-btn').forEach(function (b) {
          b.classList.remove('!border-accent-blue', '!text-accent-blue');
        });
        applyFilters();
      });

      // Initial filter application
      applyFilters();

      // Hide skeleton after filters applied
      var skeleton = document.getElementById('skeleton-grid');
      if (skeleton) skeleton.style.display = 'none';
    })();
  </script>
</BaseLayout>
