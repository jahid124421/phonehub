---
import ProductLayout from '../../layouts/ProductLayout.astro';
import RatingBadge from '../../components/RatingBadge.astro';
import SpecTable from '../../components/SpecTable.astro';
import ProductCard from '../../components/ProductCard.astro';
import { formatPrice, formatDate, getCategoryLabel, getCategoryIcon } from '../../utils/formatters';

import allProducts from '../../../data/products.json';
import allSpecs from '../../../data/specs.json';
import allBrands from '../../../data/brands.json';

export function getStaticPaths() {
  return allProducts.map((p: any) => ({
    params: { slug: p.id },
    props: { product: p },
  }));
}

const { product } = Astro.props;

// Look up detailed specs
const specs = (allSpecs as Record<string, any>)[product.id] || null;

// Look up brand data
const brandData = (allBrands as any[]).find(
  (b) => b.id === product.brand || b.id === product.brand?.toLowerCase()
);

// Related products: same brand first, then same category, exclude current
const related = (allProducts as any[])
  .filter((p) => p.id !== product.id)
  .sort((a, b) => {
    const aSameBrand = a.brand === product.brand ? 1 : 0;
    const bSameBrand = b.brand === product.brand ? 1 : 0;
    const aSameCat = a.category === product.category ? 1 : 0;
    const bSameCat = b.category === product.category ? 1 : 0;
    const aScore = aSameBrand * 2 + aSameCat;
    const bScore = bSameBrand * 2 + bSameCat;
    if (bScore !== aScore) return bScore - aScore;
    return (b.popularity || 0) - (a.popularity || 0);
  })
  .slice(0, 4);

// Quick specs entries (non-empty)
const quickSpecEntries = product.quickSpecs
  ? Object.entries(product.quickSpecs).filter(([_, v]) => v && String(v).trim())
  : [];

const specIcons: Record<string, string> = {
  display: '📱',
  processor: '⚡',
  ram: '🧠',
  storage: '💾',
  camera: '📷',
  battery: '🔋',
};

const price = formatPrice(product.basePrice);
const catLabel = getCategoryLabel(product.category);
const catIcon = getCategoryIcon(product.category);
const releaseDate = formatDate(product.releaseDate);
---

<ProductLayout product={product}>
  <!-- Breadcrumb -->
  <nav class="max-w-7xl mx-auto px-4 pt-6 pb-2" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-xs text-gray-500">
      <li><a href="/phonehub/" class="hover:text-accent-blue transition-colors">Home</a></li>
      <li class="text-gray-700">/</li>
      <li>
        <a href={`/phonehub/search?cat=${product.category}`} class="hover:text-accent-blue transition-colors">
          {catLabel}
        </a>
      </li>
      <li class="text-gray-700">/</li>
      {brandData && (
        <>
          <li>
            <a href={`/phonehub/search?brand=${brandData.id}`} class="hover:text-accent-blue transition-colors">
              {brandData.name}
            </a>
          </li>
          <li class="text-gray-700">/</li>
        </>
      )}
      <li class="text-gray-300 truncate max-w-[200px]">{product.name}</li>
    </ol>
  </nav>

  <!-- Product Hero Section -->
  <section class="max-w-7xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <!-- Left: Image -->
      <div class="flex items-center justify-center">
        <div class="relative w-full max-w-md glass-card p-6 rounded-3xl shadow-2xl">
          <img
            src={product.image || product.fallbackImg}
            alt={product.name}
            class="w-full h-auto max-h-[420px] object-contain rounded-xl"
            width="400"
            height="420"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <div class="hidden items-center justify-center h-64 text-gray-600">
            <svg class="w-20 h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Right: Info -->
      <div class="flex flex-col gap-4">
        <!-- Brand badge -->
        {brandData && (
          <a
            href={`/phonehub/search?brand=${brandData.id}`}
            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-700/60 border border-white/10 text-xs font-semibold text-gray-300 hover:text-white hover:border-accent-blue/40 transition-all w-fit"
          >
            {brandData.logo && !brandData.logo.startsWith('📱') ? (
              <img src={brandData.logo} alt={brandData.name} class="w-5 h-5 rounded-full object-contain" />
            ) : null}
            {brandData.name}
          </a>
        )}

        <!-- Product Name -->
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight">
          {product.name}
        </h1>

        <!-- Category + Release Date -->
        <div class="flex flex-wrap items-center gap-3">
          <span class="px-3 py-1 rounded-full bg-accent-blue/10 border border-accent-blue/20 text-xs font-medium text-accent-blue">
            {catIcon} {catLabel}
          </span>
          {releaseDate && (
            <span class="text-xs text-gray-500">
              Released {releaseDate}
            </span>
          )}
        </div>

        <!-- Rating -->
        {product.rating > 0 && (
          <div class="flex items-center gap-4">
            <RatingBadge rating={product.rating} reviewCount={product.reviewCount} />
          </div>
        )}

        <!-- Price -->
        <div class="flex items-center gap-4 mt-2">
          {price !== 'Check price' ? (
            <span class="text-2xl font-bold text-accent-blue">{price}</span>
          ) : (
            <span class="text-sm text-gray-500">Price varies by retailer</span>
          )}
        </div>

        <!-- Action buttons -->
        <div class="flex flex-wrap gap-3 mt-4">
          {product.basePrice > 0 && (
            <span class="px-5 py-2.5 rounded-xl bg-accent-blue/10 border border-accent-blue/30 text-accent-blue text-sm font-semibold">
              Starting at {price}
            </span>
          )}
          <a
            href={`/phonehub/compare?id=${product.id}`}
            class="px-5 py-2.5 rounded-xl bg-navy-700 border border-white/10 text-gray-300 text-sm font-semibold hover:bg-navy-600 hover:text-white hover:border-white/20 transition-all flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Compare
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Specs Grid -->
  {quickSpecEntries.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-8">
      <h2 class="text-xl font-bold text-white mb-6">Key Specifications</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {quickSpecEntries.map(([key, val]) => (
          <div class="glass-card p-4 flex flex-col gap-2">
            <div class="flex items-center gap-2">
              <span class="text-lg">{specIcons[key] || '📋'}</span>
              <span class="text-xs font-semibold uppercase tracking-wider text-gray-500">{key}</span>
            </div>
            <p class="text-sm text-gray-300 leading-relaxed line-clamp-3">
              {String(val).split(',')[0]}
            </p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Full Specifications -->
  <section class="max-w-7xl mx-auto px-4 py-8">
    <h2 class="text-xl font-bold text-white mb-6">Full Specifications</h2>
    {specs ? (
      <SpecTable specs={specs} />
    ) : quickSpecEntries.length > 0 ? (
      <div class="glass-card p-6">
        <p class="text-xs text-gray-500 mb-4">Detailed specs not yet available. Here are the key highlights:</p>
        <ul class="space-y-3">
          {quickSpecEntries.map(([key, val]) => (
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-4">
              <span class="text-xs font-semibold uppercase tracking-wider text-gray-500 sm:w-28 flex-shrink-0">
                {key}
              </span>
              <span class="text-sm text-gray-300">{String(val)}</span>
            </li>
          ))}
        </ul>
      </div>
    ) : (
      <p class="text-sm text-gray-500">Specifications not yet available for this product.</p>
    )}
  </section>

  <!-- AI Review Section -->
  {product.review && (
    <section class="max-w-7xl mx-auto px-4 py-8">
      <h2 class="text-xl font-bold text-white mb-6">AI Review</h2>
      <div class="glass-card p-6 md:p-8">
        <p class="text-gray-300 leading-relaxed text-sm md:text-base">
          {product.review}
        </p>

        {(product.pros?.length > 0 || product.cons?.length > 0) && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
            <!-- Pros -->
            {product.pros?.length > 0 && (
              <div>
                <h3 class="text-sm font-semibold text-green-400 mb-3 flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Pros
                </h3>
                <ul class="space-y-2">
                  {product.pros.map((pro: string) => (
                    <li class="flex items-start gap-2 text-sm text-gray-300">
                      <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                          d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                          clip-rule="evenodd" />
                      </svg>
                      {pro}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Cons -->
            {product.cons?.length > 0 && (
              <div>
                <h3 class="text-sm font-semibold text-red-400 mb-3 flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                  Cons
                </h3>
                <ul class="space-y-2">
                  {product.cons.map((con: string) => (
                    <li class="flex items-start gap-2 text-sm text-gray-300">
                      <svg class="w-4 h-4 text-red-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                          d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                          clip-rule="evenodd" />
                      </svg>
                      {con}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        )}

        <p class="text-[10px] text-gray-600 mt-6 italic">
          This review was generated by AI and may not reflect real user experiences. Always do your own research before purchasing.
        </p>
      </div>
    </section>
  )}

  <!-- Price Comparison -->
  {product.prices?.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-8">
      <h2 class="text-xl font-bold text-white mb-6">Where to Buy</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {product.prices.map((store: any) => (
          <div class="glass-card p-5 flex flex-col gap-3">
            <div class="flex items-center justify-between">
              <h3 class="text-sm font-semibold text-white">{store.store}</h3>
              {store.price ? (
                <span class="text-lg font-bold text-accent-blue">
                  {formatPrice(store.price)}
                </span>
              ) : (
                <span class="text-xs text-gray-500">Check site</span>
              )}
            </div>
            <a
              href={store.url}
              target="_blank"
              rel="nofollow noopener noreferrer"
              class="block w-full text-center px-4 py-2.5 rounded-xl bg-accent-blue/10 border border-accent-blue/30 text-accent-blue text-sm font-semibold hover:bg-accent-blue/20 hover:border-accent-blue/50 transition-all"
            >
              Check Price &rarr;
            </a>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Related Products -->
  {related.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-12">
      <h2 class="text-xl font-bold text-white mb-6">You Might Also Like</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {related.map((p) => (
          <ProductCard product={p} size="sm" />
        ))}
      </div>
    </section>
  )}
</ProductLayout>
